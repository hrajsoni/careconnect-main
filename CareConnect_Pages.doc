                    &gt;
                      &lt;span className=&quot;inline-flex items-center gap-2&quot;&gt;
                        &lt;RefreshCw
                          className={`w-4 h-4 ${
                            refreshingProfile ? &quot;animate-spin&quot; : &quot;&quot;
                          }`}
                        /&gt;
                        {refreshingProfile ? &quot;Refreshing...&quot; : &quot;Refresh&quot;}
                      &lt;/span&gt;
                    &lt;/button&gt;

                    &lt;Button
                      type=&quot;button&quot;
                      onClick={openEditModal}
                      className=&quot;rounded-2xl bg-teal-600 text-white hover:bg-teal-700&quot;
                    &gt;
                      &lt;span className=&quot;inline-flex items-center gap-2&quot;&gt;
